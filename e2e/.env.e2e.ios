# e2e/.env.e2e.ios
# Environment file for iOS Simulator E2E builds (react-native-config).
#
# The iOS Simulator maps the host's localhost directly (127.0.0.1).
# On the macOS CI runner, Harmony Link runs as a native Go binary (not Docker)
# and listens on localhost:28443.
#
# Usage:
#   ENVFILE=e2e/.env.e2e.ios npm run build:ios:simulator
#
# Phase 4-1 override (implemented):
# When HARMONY_LINK_WSS_URL + HARMONY_LINK_WS_URL are set,
# ConnectionStateManager.applyE2EOverride() pre-seeds pairing state on boot.
# See e2e/.env.e2e for the full documentation.

# Same as .env.e2e but for iOS Simulator testing on macOS CI runner.
# iOS Simulator reaches the host via localhost (not 10.0.2.2).
HARMONY_LINK_WSS_URL=wss://localhost:28443
HARMONY_LINK_WS_URL=ws://localhost:28080
IS_BETA=true
