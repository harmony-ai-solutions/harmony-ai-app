# e2e/.env.e2e
# Reference values for the E2E build configuration.
#
# Build command (the -P flags are required; this file is just documentation):
#   cd android && ./gradlew assembleDevDebug \
#     -PHARMONY_LINK_WSS_URL=wss://10.0.2.2:28443 \
#     -PHARMONY_LINK_WS_URL=ws://10.0.2.2:28080
#
# Or use the helper script (passes the -P flags automatically):
#   ./e2e/build-apk.sh        (Linux/macOS/WSL)
#   ./e2e/build-apk.ps1       (Windows PowerShell)
#
# Then copy the APK into place:
#   cp android/app/build/outputs/apk/dev/debug/app-dev-debug.apk e2e/app-debug.apk
#
# Android emulator reaches the host via the special IP 10.0.2.2.
# Harmony Link must be running in the Docker Compose stack
# (e2e/docker-compose.yml) on ports 28080 (WS) and 28443 (WSS).
#
# Phase 4-1 override (implemented):
# When HARMONY_LINK_WSS_URL + HARMONY_LINK_WS_URL are non-empty (passed via
# -P flags), gradle's buildConfigField surfaces them via
# Config.HARMONY_LINK_WSS_URL / Config.HARMONY_LINK_WS_URL in JS.
# ConnectionStateManager.applyE2EOverride() then pre-seeds AsyncStorage so
# the app boots already paired against the harmony-link container —
# skipping the manual pairing UI for E2E runs.
# See src/services/ConnectionStateManager.ts:applyE2EOverride.

HARMONY_LINK_WSS_URL=wss://10.0.2.2:28443
HARMONY_LINK_WS_URL=ws://10.0.2.2:28080
IS_BETA=true
