# react-native-config (iOS) + build-time reference.
# On Android these come from productFlavors buildConfigField (android/app/build.gradle), NOT this file.
# On iOS, react-native-config reads this file (repo root); CI regenerates it per environment before xcodebuild
# (see .github/workflows/build-release.yml). Local dev: __DEV__ short-circuits IS_BETA to true regardless,
# so this file only affects RELEASE builds. Values are non-sensitive (ship in client binaries).
IS_BETA=true
GOOGLE_WEB_CLIENT_ID=
APPLE_SERVICES_ID=

# E2E testing override — set ONLY in e2e/.env.e2e, never in production .env.
# When both are present, ConnectionStateManager.applyE2EOverride() pre-seeds
# pairing state on app boot so the app connects to the harmony-link container
# automatically (cloud-mode auto-approval handles device registration).
# Unset in regular builds. See e2e/.env.e2e for full docs.
# HARMONY_LINK_WSS_URL=wss://10.0.2.2:28443
# HARMONY_LINK_WS_URL=ws://10.0.2.2:28080
