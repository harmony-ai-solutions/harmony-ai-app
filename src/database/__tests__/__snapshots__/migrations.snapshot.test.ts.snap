CREATE TABLE interactions ( id TEXT PRIMARY KEY NOT NULL, entity_id TEXT NOT NULL, interaction_scope TEXT NOT NULL, participant_key TEXT, participant_ids TEXT NOT NULL, status TEXT NOT NULL DEFAULT 'active', started_at TEXT NOT NULL, last_activity_at TEXT NOT NULL, ended_at TEXT, metadata TEXT, deleted_at TEXT, created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP, updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP , summary TEXT DEFAULT '', memory_id TEXT, continued_interaction_id TEXT, presence_type TEXT NOT NULL DEFAULT 'unknown');

